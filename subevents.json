 con il suo doloroso passato."},"seating_plan":3938,"item_price_overrides":[{"item":264975,"price":null,"disabled":false,"available_from":null,"available_until":null},{"item":265273,"price":null,"disabled":false,"available_from":null,"available_until":null}],"variation_price_overrides":[],"meta_data":{},"seat_category_mapping":{"Category V":264975},"last_modified":"2022-11-30T20:31:40.481134+01:00","comment":null},{"id":3754241,"name":{"it":"SUSPIRIA"},"date_from":"2022-12-04T16:00:00+01:00","date_to":null,"active":true,"date_admission":null,"presale_start":null,"presale_end":null,"location":{"it":"MILANO"},"geo_lat":45.4641943,"geo_lon":9.1896346,"event":"npkez","is_public":true,"frontpage_text":{},"seating_plan":3938,"item_price_overrides":[{"item":264975,"price":null,"disabled":false,"available_from":null,"available_until":null},{"item":265273,"price":null,"disabled":false,"available_from":null,"available_until":null}],"variation_price_overrides":[],"meta_data":{},"seat_category_mapping":{"Category V":264975},"last_modified":"2022-12-04T15:34:58.959821+01:00","comment":null},{"id":3756691,"name":{"it":"LA BUSSOLA D'ORO"},"date_from":"2022-12-07T21:00:00+01:00","date_to":"2022-12-07T23:00:00+01:00","active":true,"date_admission":null,"presale_start":null,"presale_end":null,"location":{"it":"MILANO"},"geo_lat":45.4641943,"geo_lon":9.1896346,"event":"npkez","is_public":true,"frontpage_text":{},"seating_plan":3945,"item_price_overrides":[{"item":264975,"price":null,"disabled":false,"available_from":null,"available_until":null},{"item":265273,"price":null,"disabled":false,"available_from":null,"available_until":null}],"variation_price_overrides":[],"meta_data":{},"seat_category_mapping":{"Category I":264975},"last_modified":"2022-12-07T20:15:05.021269+01:00","comment":null},{"id":3756692,"name":{"it":"BROS"},"date_from":"2022-12-08T00:00:00+01:00","date_to":"2022-12-08T02:00:00+01:00","active":true,"date_admission":null,"presale_start":null,"presale_end":"2022-12-07T2