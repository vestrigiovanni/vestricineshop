generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MovieOverride {
  tmdbId             String       @id
  customTitle        String?
  customOverview     String?
  customRating       String?
  customPosterPath   String?
  customBackdropPath String?
  customTrailerUrl   String?
  customTrailerTitle String?
  versionLanguage    String?
  subtitles          String?
  customVersion      String?
  customRoomName     String?
  manualSoldOut      Boolean      @default(false)
  updatedAt          DateTime     @updatedAt
  isManualOverride   Boolean      @default(false)
  isDraft            Boolean      @default(false)
  customDirector     String?
  customCast         String?
  customLogoPath     String?
  releaseDate        String?
  runtime            Int?
  mubiId             String?
  customTrailerKeys  String[]     @default([])
  tagline            String?
  extraBackdrops     String[]     @default([])
  awards             MovieAward[]
  projections        PretixSync[]
}

model MovieAward {
  id      String        @id @default(cuid())
  tmdbId  String
  type    String
  label   String
  details String?
  year    Int?
  movie   MovieOverride @relation(fields: [tmdbId], references: [tmdbId], onDelete: Cascade)

  @@index([tmdbId])
}

model PretixSync {
  pretixId        Int            @id
  name            String
  slug            String?
  dateFrom        DateTime
  seatingPlanId   Int?
  roomName        String?
  isSoldOut       Boolean        @default(false)
  tmdbId          String?
  comment         String?
  metaLingua      String?
  metaSottotitoli String?
  metaFormat      String?
  active          Boolean        @default(true)
  isHidden        Boolean        @default(false)
  updatedAt       DateTime       @updatedAt
  availableSeats  Int?
  dateTo          DateTime?
  totalSeats      Int?
  endTime         String?
  startTime       String?
  movie           MovieOverride? @relation(fields: [tmdbId], references: [tmdbId])
}

model CatalogFilm {
  id           Int       @id @default(autoincrement())
  sourceKey    String    @unique // chiave naturale normalizzata "titolo|anno" per upsert ripetibile

  // --- Dal CSV ---
  title        String
  year         Int?
  durationMin  Int?
  director     String?

  // --- Abbinati da TMDB (snapshot all'import) ---
  tmdbId       String?
  tmdbTitle    String?
  tmdbYear     Int?
  posterPath   String?
  genres       String[]  @default([])
  runtime      Int?

  // --- Qualità / verifica ---
  verifyStatus String    @default("pending") // pending | ok | suspect | missing | fixed
  enrichedAt   DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tmdbId])
  @@index([verifyStatus])
}
