generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MovieOverride {
  tmdbId             String       @id
  customTitle        String?
  customOverview     String?
  customRating       String?
  customPosterPath   String?
  customBackdropPath String?
  customTrailerUrl   String?
  customTrailerTitle String?
  versionLanguage    String?
  subtitles          String?
  customRoomName     String?
  manualSoldOut      Boolean      @default(false)
  updatedAt          DateTime     @updatedAt
  isManualOverride   Boolean      @default(false)
  isDraft            Boolean      @default(false)
  customDirector     String?
  customCast         String?
  customLogoPath     String?
  releaseDate        String?
  runtime            Int?
  mubiId             String?
  customTrailerKeys  String[]     @default([])
  awards             MovieAward[]
  projections        PretixSync[]
}

model MovieAward {
  id      String        @id @default(cuid())
  tmdbId  String
  type    String
  label   String
  details String?
  year    Int?
  movie   MovieOverride @relation(fields: [tmdbId], references: [tmdbId], onDelete: Cascade)

  @@index([tmdbId])
}

model PretixSync {
  pretixId        Int            @id
  name            String
  slug            String?
  dateFrom        DateTime
  seatingPlanId   Int?
  roomName        String?
  isSoldOut       Boolean        @default(false)
  tmdbId          String?
  comment         String?
  metaLingua      String?
  metaSottotitoli String?
  metaFormat      String?
  active          Boolean        @default(true)
  isHidden        Boolean        @default(false)
  updatedAt       DateTime       @updatedAt
  availableSeats  Int?
  dateTo          DateTime?
  totalSeats      Int?
  endTime         String?
  startTime       String?
  movie           MovieOverride? @relation(fields: [tmdbId], references: [tmdbId])
}
